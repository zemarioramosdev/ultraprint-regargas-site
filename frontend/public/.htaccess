<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redireciona tudo que não for um arquivo físico ou pasta para o index.html (Next.js Routing)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
